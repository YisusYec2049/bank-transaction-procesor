# ══════════════════════════════════════════════════════════════════
#  ENTORNO DE PRUEBA — nunca apuntar a producción desde este VPS
#  Copiar a .env y completar los valores reales de prueba.
# ══════════════════════════════════════════════════════════════════

# ── Google Service Account ─────────────────────────────────────────
# Ruta absoluta al JSON de la cuenta de servicio.
GOOGLE_SA_JSON=/opt/matching/service_account.json

# ── Spreadsheet CONSOLIDADO (PRUEBA) ──────────────────────────────
# Hoja maestra donde se crean tabs por día (DD-MM-YYYY) y se
# acumulan los registros normalizados de todos los bancos.
CONSOLIDADO_SHEET_ID=HOJA_PRUEBA_CONSOLIDADO_ID

# ── Spreadsheet CHEQUES_PENDIENTES (PRUEBA) ───────────────────────
# Hoja donde se registran cheques en espera de ser cobrados.
CHEQUES_SHEET_ID=HOJA_PRUEBA_CHEQUES_PENDIENTES_ID

# ── Carpetas Drive – Bancolombia 2576 (PRUEBA) ────────────────────
# Carpeta donde el banco deposita los PDFs diarios (copia de prueba).
BC2576_INBOX_FOLDER_ID=CARPETA_PRUEBA_BC2576_INBOX_ID

# Carpeta Histórico: los PDFs se mueven aquí tras procesarse.
BC2576_HISTORICO_FOLDER_ID=CARPETA_PRUEBA_BC2576_HISTORICO_ID

# ── Bancolombia 2833 ──────────────────────────────────────────────
BC2833_INBOX_FOLDER_ID=CARPETA_PRUEBA_BC2833_INBOX_ID
BC2833_HISTORICO_FOLDER_ID=CARPETA_PRUEBA_BC2833_HISTORICO_ID
BC2833_CONSOLIDADO_SHEET_ID=HOJA_PRUEBA_CONSOLIDADO_ID
BC2833_CHEQUES_SHEET_ID=HOJA_PRUEBA_CHEQUES_PENDIENTES_ID

# ── Placetopay ────────────────────────────────────────────────────
PLACETOPAY_INBOX_FOLDER_ID=
PLACETOPAY_HISTORICO_FOLDER_ID=

# ── WOMPI ─────────────────────────────────────────────────────────
WOMPI_INBOX_FOLDER_ID=
WOMPI_HISTORICO_FOLDER_ID=

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_INBOX_FOLDER_ID=
STRIPE_HISTORICO_FOLDER_ID=

# ── Colpatria ─────────────────────────────────────────────────────
COLPATRIA_INBOX_FOLDER_ID=
COLPATRIA_HISTORICO_FOLDER_ID=

# ── Davivienda ────────────────────────────────────────────────────
DAVIVIENDA_INBOX_FOLDER_ID=
DAVIVIENDA_HISTORICO_FOLDER_ID=

# ── PayU ──────────────────────────────────────────────────────────
PAYU_INBOX_FOLDER_ID=
PAYU_HISTORICO_FOLDER_ID=
PAYU_MONEDA_INBOX_FOLDER_ID=
PAYU_MONEDA_HISTORICO_FOLDER_ID=

# ── Cruce de Cartera — carpeta única (LEGACY, fallback) ───────────────────
# Usada si alguna de las carpetas nuevas de abajo no está seteada. Antes de
# la Spec C (21 de julio) los 3 archivos vivían todos acá.
CARTERA_DRIVE_FOLDER_ID=

# ── Cruce de Cartera — una carpeta por archivo (Spec C, 21 de julio) ──────
# Payu UC.xlsx
PAYU_UC_FOLDER_ID=
PAYU_UC_HIST_FOLDER_ID=
# Ingresos PSE y PAYU.xlsx
INGRESOS_FOLDER_ID=
INGRESOS_HIST_FOLDER_ID=
# CARTERA PREVENTIVA*.xlsx (nombre variable, se busca por patrón)
CARTERA_PREV_FOLDER_ID=
CARTERA_PREV_HIST_FOLDER_ID=

# ── Reporte ReportePagosWompi_*.xlsx (subcarpeta "wompi" dentro de Archivos Cruce) ──
# Se lee directo desde cruzar.py (no se sincroniza a una tabla mirror).
WOMPI_REPORTE_DRIVE_FOLDER_ID=

# ── Control temporal ──────────────────────────────────────────────
# Poner 'true' para escribir solo en Sheets y omitir el upsert a Supabase.
# Quitar o poner 'false' cuando se quiera activar la inserción real.
SKIP_SUPABASE=false

# ── Supabase (PRUEBA) ──────────────────────────────────────────────
# Usar proyecto de prueba, NUNCA el proyecto de producción.
SUPABASE_URL=https://PROYECTO_PRUEBA.supabase.co
SUPABASE_SERVICE_ROLE_KEY=SERVICE_ROLE_KEY_DEL_PROYECTO_PRUEBA

# ── Trigger HTTP bajo demanda (trigger_server.py) ─────────────────
# Token compartido — financial-platform debe mandarlo como
# "Authorization: Bearer <TRIGGER_TOKEN>". Generar con:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
TRIGGER_TOKEN=GENERAR_TOKEN_ALEATORIO
